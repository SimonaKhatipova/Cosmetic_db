# ──────────────────────────────────────────────────
# Beauty Helper — переменные окружения
# ──────────────────────────────────────────────────
# Скопируйте этот файл в .env и заполните значения.
# НИКОГДА не добавляйте .env в git (он уже в .gitignore).

# CloudPayments — Public ID (открытый ключ, безопасен для фронтенда)
# Получить в личном кабинете cloudpayments.ru → Магазины → API
# Тестовый ключ начинается с pk_test_...
VITE_CLOUDPAYMENTS_PUBLIC_ID=pk_test_xxxxxxxxxxxxxxxxxxxxxxx

# CloudPayments — Secret Key (секретный ключ)
# ТОЛЬКО для бэкенда/Supabase Edge Functions, НИКОГДА не добавлять сюда
# CP_SECRET_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxx

# Supabase (уже используется в App.jsx, дублировать не нужно если hardcoded)
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_KEY=eyJxxxx
